{
    "compilerOptions": {
        "target": "ESNext",
        "lib": ["DOM", "ESNext"],
        "module": "ESNext",

        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",

        "strict": true,
        "types": ["vite/client", "node"],

        "paths": {
            "@/*": ["./resources/js/*"]
        }
    },
    "include": ["resources/js"]
}
